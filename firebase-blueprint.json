{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user settings and profile information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique identifier for the user." },
        "displayName": { "type": "string", "description": "User's display name." },
        "email": { "type": "string", "format": "email", "description": "User's email address." },
        "photoURL": { "type": "string", "description": "URL to user's profile photo." },
        "role": { "type": "string", "enum": ["user", "admin"], "description": "User's role in the system." },
        "currency": { "type": "string", "description": "User's preferred currency." },
        "darkMode": { "type": "boolean", "description": "Whether dark mode is enabled." },
        "notifications": { "type": "boolean", "description": "Whether notifications are enabled." },
        "lastSynced": { "type": "string", "format": "date-time", "description": "Last time the user's data was synced." }
      },
      "required": ["uid", "email", "role"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile document."
    }
  }
}

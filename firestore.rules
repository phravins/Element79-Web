rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required, immutable) - User's unique ID
    //   - displayName: string (optional) - User's display name
    //   - email: string (required, immutable) - User's email address
    //   - photoURL: string (optional) - User's profile photo URL
    //   - role: string (required, enum: ['user', 'admin']) - User's role
    //   - currency: string (optional) - User's preferred currency
    //   - darkMode: bool (optional) - Dark mode preference
    //   - notifications: bool (optional) - Notification preference
    //   - lastSynced: string (optional) - Last sync timestamp
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isVerified() {
      return isAuthenticated() && request.auth.token.email_verified == true;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }
    
    function isValidUser(data) {
      return data.uid is string && data.uid.size() > 0 &&
             data.email is string && data.email.size() > 0 &&
             data.role in ['user', 'admin'] &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() < 100)) &&
             (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() < 1000)) &&
             (!('currency' in data) || (data.currency is string && data.currency.size() < 10)) &&
             (!('darkMode' in data) || data.darkMode is bool) &&
             (!('notifications' in data) || data.notifications is bool) &&
             (!('lastSynced' in data) || data.lastSynced is string);
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /users/{userId} {
      // Users can only read their own profile
      allow read: if isOwner(userId) && isVerified();
      
      // Users can create their own profile if verified
      allow create: if isOwner(userId) && isVerified() && 
                      isValidUser(request.resource.data) &&
                      request.resource.data.uid == request.auth.uid &&
                      request.resource.data.email == request.auth.token.email &&
                      request.resource.data.role == 'user'; // Default role
      
      // Users can update their own profile, but cannot change uid, email, or role
      allow update: if isOwner(userId) && isVerified() && 
                      isValidUser(request.resource.data) &&
                      request.resource.data.uid == resource.data.uid &&
                      request.resource.data.email == resource.data.email &&
                      request.resource.data.role == resource.data.role;
    }

    // Default deny
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
